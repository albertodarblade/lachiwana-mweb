{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
        "permission": {
          "bash": {
            "*": "allow"
          },
          "external_directory": {
            "../Lachiwana-service/**": "allow"
          }
        }
      },
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "write": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "explore": {
      "permission": {
        "external_directory": {
          "../Lachiwana-service/**": "allow"
        }
      }
    },
    "general": {
      "permission": {
        "external_directory": {
          "../Lachiwana-service/**": "allow"
        }
      }
    }
  },
  "permission": {
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "../Lachiwana-service/**": "allow"
    }
  },
  "formatter": true,
  "instructions": [
    "AGENTS.md",
    "specs/015-sliding-session-auth/plan.md"
  ]
}
